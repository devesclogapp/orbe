      "id": "download-file-1",
      "name": "Baixar arquivo do Drive",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        -380,
        -160
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "COLE_ID_CREDENCIAL_GOOGLE",
          "name": "Google Drive ESC LOG"
        }
      },
      "notes": "Baixa o arquivo criado na pasta Entrada."
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary || {};\n\nconst fileName = json.name || json.fileName || json.originalFilename || json.title || 'arquivo_sem_nome';\nconst ext = fileName.includes('.') ? fileName.split('.').pop().toLowerCase() : '';\n\nconst allowed = ['txt', 'csv', 'afd', 'xlsx', 'xls'];\nconst tipo =\n  ext === 'afd' || fileName.toLowerCase().includes('afd') ? 'AFD' :\n  ext === 'csv' ? 'CSV' :\n  ext === 'txt' ? 'TXT' :\n  ext === 'xlsx' || ext === 'xls' ? 'EXCEL' :\n  'DESCONHECIDO';\n\nreturn [{\n  json: {\n    ...json,\n    fileName,\n    extension: ext,\n    tipo_arquivo: tipo,\n    extensao_valida: allowed.includes(ext) || tipo === 'AFD',\n    data_recebimento: new Date().toISOString()\n  },\n  binary\n}];"
      },
      "id": "code-validar-1",
      "name": "Validar arquivo e tipo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -120,
        -160
      ],
      "notes": "Identifica nome, extensão e tipo do arquivo."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-ext-valida",
              "leftValue": "={{ $json.extensao_valida }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-extensao-1",
      "name": "IF - Extensao valida?",
