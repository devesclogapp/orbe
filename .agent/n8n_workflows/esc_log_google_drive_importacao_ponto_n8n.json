              "name": "origem",
              "value": "={{ $json.origem }}"
            },
            {
              "parameterType": "formData",
              "name": "nome_arquivo",
              "value": "={{ $json.fileName }}"
            },
            {
              "parameterType": "formData",
              "name": "tipo_arquivo",
              "value": "={{ $json.tipo_arquivo }}"
            },
            {
              "parameterType": "formData",
              "name": "data_recebimento",
              "value": "={{ $json.data_recebimento }}"
            },
            {
              "parameterType": "formBinaryData",
              "name": "arquivo",
              "inputDataFieldName": "data"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": true
            }
          }
        }
      },
